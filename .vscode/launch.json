{
  "$schema": "vscode://schemas/launch",
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run: Dev (watch + inspect)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:electron:inspect"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      },
      "preLaunchTask": "npm: dev:renderer"
    },
    {
      "name": "Attach: Electron Main (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Attach: Renderer (9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/dist",
      "timeout": 30000
    }
  ],
  "compounds": [
    {
      "name": "Full Debug: Main + Renderer",
      "configurations": [
        "Run: Dev (watch + inspect)",
        "Attach: Electron Main (9229)",
        "Attach: Renderer (9222)"
      ]
    }
  ]
}
